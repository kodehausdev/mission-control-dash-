# This app's own public URL — used to build the redirect link in operator
# invite emails (Settings → Team → Invite member). Update for production.
APP_URL=http://localhost:3002

# medlab-engine base URL (dashboard feed: /api/dashboard/state + /events SSE,
# /health). Mission Control degrades gracefully when unreachable.
ENGINE_URL=http://localhost:3000

# Supabase — shared instance with medlab-engine/medlab-web.
# Anon key is used only for the login form (Supabase Auth session).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. ALL Mission Control data access is service-role behind the
# operator gate — Mission Control tables have no anon/authenticated RLS
# policies at all. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — server-only. Billing screen, MRR, invoices, retries.
STRIPE_SECRET_KEY=

# Resend — server-only. Mission Control sends its own operator invite/reset
# emails through this instead of Supabase's built-in mailer (which is rate
# limited and was unreliable in practice). FROM must be on a domain verified
# in the Resend account.
RESEND_API_KEY=
EMAIL_FROM=Mission Control <mission-control@optipropose.com>
